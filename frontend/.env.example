# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local al repositorio

# Google OAuth2 — Client ID del proyecto en Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# URL base del backend (en desarrollo usa el proxy de Vite, en prod la URL real)
VITE_API_URL=http://localhost:8080/api
